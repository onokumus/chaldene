---
import CssVendor from "../components/CssVendor.astro";
import JsVendor from '../components/JsVendor.astro';
export interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="favicon.svg" />
		<link rel="icon" href="favicon.ico" />
		<meta name="generator" content={Astro.generator} />
    <title>Chaldene - {title}</title>
    <CssVendor />

    <slot name="head" />
  </head>
  <body>
    <!-- BEGIN .app -->
    <div class="app">
      <!-- BEGIN .app-wrap -->
      <div class="app-wrap">
        <slot name="body" />
      </div>
      <!-- END .app-wrap -->
    </div>
    <!-- END .app -->
    <JsVendor />
    <slot name="footer" />
  </body>
</html>
